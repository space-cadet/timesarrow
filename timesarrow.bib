	issn = {00034916},
	journal = {Annals of Physics},
	keywords = {Quantum coding theory,Self-correcting quantum memory,Stabilizer formalism,Thermal stability,Topological phase,Topological quantum field theory},
	mendeley-groups = {Loop Quantum Gravity,Quantum Error Correction},
	month = {mar},
	number = {10},
	pages = {2566--2633},
	title = {{Feasibility of self-correcting quantum memory and thermal stability of topological order}},
	url = {http://arxiv.org/abs/1103.1885 http://dx.doi.org/10.1016/j.aop.2011.06.001},

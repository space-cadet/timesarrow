	Date-Added = {2016-12-01 07:44:20 +0000},
	Date-Modified = {2016-12-01 07:44:20 +0000},
	Day = {25},
	Eprint = {1606.07975},
	Keywords = {accelerated\_expansion, arrow\_of\_time, cosmology, gravitational\_waves, ligo, maguire\_shaun, manybody, muller\_richard, quantum\_gravity, time},
	Month = jun,
	Posted-At = {2016-10-24 15:12:14},

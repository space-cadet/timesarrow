	day = {29},
	doi = {10.1038/nphys444},
	issn = {1745-2473},
	journal = {Nature Physics},
	keywords = {boltzmann\_weights, canonical\_ensemble, entanglement, foundations, pedagogical, quantum\_mechanics, statistical\_mechanics},
	month = nov,

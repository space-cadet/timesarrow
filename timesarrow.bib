	mendeley-groups = {Time Reversal in LQG},
	mendeley-tags = {time{\_}reversal,arrow of time,quantum gravity,symmetry,quantum mechanics,thesis,roberts{\_}bryan{\_}w,antiunitary transformations,wigners theorem},
	pages = {112},
	title = {{Time, symmetry and structure: a study in the foundations of quantum theory}},
	url = {https://philpapers.org/rec/ROBTSA-6},
	year = {2012},
	bdsk-url-1 = {https://philpapers.org/rec/ROBTSA-6}}


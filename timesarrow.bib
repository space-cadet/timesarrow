	issn = {10980121},
	journal = {Physical Review B - Condensed Matter and Materials Physics},
	mendeley-groups = {Time Reversal in LQG},
	number = {6},
	title = {{Entanglement spectrum of a topological phase in one dimension}},
	url = {https://arxiv.org/abs/0910.1811},
	volume = {81},

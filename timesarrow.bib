	journal = {Studies in History and Philosophy of Science Part B - Studies in History and Philosophy of Modern Physics},
	keywords = {CP violation,Generalizations of quantum mechanics,Quantum gravity,T violation},
	mendeley-groups = {Time Reversal in LQG},
	month = {nov},
	pages = {16--20},
	publisher = {Pergamon},
	title = {{Response to Bryan Roberts: A new perspective on T violation}},
	url = {https://www.sciencedirect.com/science/article/pii/S1355219814000641?via{\%}3Dihub},
	volume = {52},
	year = {2015},
	bdsk-url-1 = {https://doi.org/10.1016/j.shpsb.2014.07.001}}

@article{Ashtekar2015Time,
	abstract = {The first three sections of this paper contain a broad
		  brush summary of the profound changes in the notion of time
		  in fundamental physics that were brought about by three
		  revolutions: the foundations of mechanics distilled by
		  Newton in his Principia, the discovery of special
		  relativity by Einstein and its reformulation by Minkowski,
		  and, finally, the fusion of geometry and gravity in
		  Einstein's general relativity. The fourth section discusses
		  two aspects of yet another deep revision that waits in the
		  wings as we attempt to unify general relativity with
